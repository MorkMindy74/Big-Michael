# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Embeddings (OpenAI; swap for Voyage AI: VOYAGE_API_KEY + model voyage-3-lite)
# Not required when LOCAL_EMBEDDINGS=true
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Local inference — Ollama (https://ollama.com)
# OLLAMA_ENABLED=true routes OLLAMA_TIERS agents to local Ollama.
# Pull a model first: ollama pull llama3.2
# For tool-use: ollama pull llama3.1   or  ollama pull qwen2.5
#
# LOCAL_EMBEDDINGS=true replaces OpenAI embeddings with Ollama local embeddings.
# Pull embedding model: ollama pull nomic-embed-text   (768-dim, recommended)
#                       ollama pull all-minilm          (384-dim, fast, installed)
#                       ollama pull mxbai-embed-large   (1024-dim, high quality)
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIERS=3
LOCAL_EMBEDDINGS=false
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# Vector DB (Qdrant dev stand-in; swap URL for RuVector: https://github.com/ruvnet/RuVector)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# MCP / REST
MCP_PORT=3100
API_PORT=3101

# DyTopo
DYTOPO_SIMILARITY_THRESHOLD=0.68
DYTOPO_MAX_AGENTS_PER_ROUND=12
DYTOPO_MAX_ROUNDS=14

# Debate protocol
DEBATE_CITATION_REQUIRED=true
DEBATE_ADVERSARIAL_ENABLED=true
DEBATE_VERIFICATION_PASSES=10
DEBATE_GATE_CONFIDENCE_THRESHOLD=0.80

# Web search (Tavily — https://tavily.com, free tier available)
TAVILY_API_KEY=

# Task persistence — path to JSON file for task state across restarts
TASKS_FILE=.tasks.json

# Logging
LOG_LEVEL=info
